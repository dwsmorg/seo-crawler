{
  "format": "keep-a-changelog",
  "changelog": {
    "file": "changelog.md",
    "path": "./documentation/changelog",
    "encoding": "utf-8",
    "entrySpacing": 3
  },
  "backup": {
    "enabled": true,
    "path": "./documentation/changelog/backup",
    "strategy": "daily",
    "maxFiles": 30
  },
  "versioning": {
    "mode": "patch-only",
    "prefix": "",
    "fixedMajor": 1,
    "fixedMinor": 0
  },
  "dateFormat": "DD.MM.YYYY",
  "language": "de"
}
