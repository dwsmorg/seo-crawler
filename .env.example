# ==================================================
# SEO-Crawler-Framework - Umgebungsvariablen
# ==================================================
# Diese Datei als .env kopieren und anpassen:
#   cp .env.example .env
# ==================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_USER=seo_crawler
POSTGRES_PASSWORD=seo_crawler_dev
POSTGRES_DB=seo_crawler

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@localhost.dev
PGADMIN_DEFAULT_PASSWORD=admin

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# --- Crawler ---
CRAWL_MAX_DEPTH=10
CRAWL_CONCURRENT_REQUESTS=16
CRAWL_DOWNLOAD_DELAY=0.25
CRAWL_AUTOTHROTTLE_ENABLED=true
CRAWL_RESPECT_ROBOTS_TXT=true
